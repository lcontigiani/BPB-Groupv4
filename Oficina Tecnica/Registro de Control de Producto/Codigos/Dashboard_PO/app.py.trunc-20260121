import threading



SYNC_STATE = {

    "running": False,

    "stage": "idle", # idle, changing_dirs, step2, measuring, step3

    "progress": 0,

    "total": 0,

    "current": 0,

    "message": "",

    "source": "auto", # auto | manual

    "data_version": 0

}



def count_files_recursive(directory, extension):

    count = 0

    try:

        for path in Path(directory).rglob(f'*{extension}'):

            if path.is_file():

                count += 1

    except: pass

    return count



def count_subdirs(directory):

    count = 0

    try:

        # Count direct subdirectories

        for path in Path(directory).iterdir():

            if path.is_dir():

                count += 1

    except: pass

    return count



def background_sync_task():

    global SYNC_STATE

    SYNC_STATE["running"] = True

    SYNC_STATE["progress"] = 0

    SYNC_STATE["data_version"] = 0 # Reset version

    script_dir = Path(r"\\192.168.0.13\lcontigiani\Oficina Tecnica\Registro de Control de Producto\Codigos")

    

    try:

        import sys

        # --- ETAPA 1: STEP 2 (Descarga de PDFs) ---

        SYNC_STATE["stage"] = "step2"

        SYNC_STATE["message"] = "Descargando archivos PDF..."

        

        # LOGGING FOR DEBUGGING

        print(f"Background Sync: Using interpreter {sys.executable}")

        print(f"Background Sync: CWD is {script_dir}")

        

        # Keep progress at 0 during fetch since we can't estimate easily yet

        SYNC_STATE["progress"] = 0 

        

        # Use sys.executable to ensure same environment

        step2_cmd = [sys.executable, 'step2_fetch_pdfs.py', '--config', 'config.yaml']

        

        # Run Step 2

        result2 = subprocess.run(step2_cmd, cwd=str(script_dir), capture_output=True, text=True)

        if result2.returncode != 0:

            print(f"Step 2 Failed: {result2.stderr}")

            raise Exception(f"Fallo descarga PDF: {result2.stderr}")

        

        # --- ETAPA 2: STEP 3 (Procesar Outputs en EN PROGRESO) ---

        SYNC_STATE["stage"] = "step3"

        SYNC_STATE["message"] = "Procesando registros..."

        

        entrantes_dir = Path(r"\\192.168.0.13\lcontigiani\Oficina Tecnica\Registro de Control de Producto\P2 - Purchase Order\Entrantes")

        en_progreso_dir = Path(r"\\192.168.0.13\lcontigiani\Oficina Tecnica\Registro de Control de Producto\P2 - Purchase Order\En Progreso")

        

        total_pdfs = count_files_recursive(entrantes_dir, ".pdf")

        SYNC_STATE["total"] = total_pdfs if total_pdfs > 0 else 1 # Avoid div/0

        

        step3_cmd = [sys.executable, 'step3_prepare_outputs.py', '--config', 'config.yaml']

        

        # No usamos PIPE para stdout/stderr, dejamos que salga directo a consola para que el usuario vea el progreso real

        process3 = subprocess.Popen(step3_cmd, cwd=str(script_dir), stdout=None, stderr=None, text=True)

        

        import time

        last_folders = count_subdirs(en_progreso_dir)

        

        while process3.poll() is None:

            try:

                # 1. Update Progress

                # Logic: Processed = (Moved PDFs) + (PDFs currently processed i.e. have JSON)

                pdfs_remaining = count_files_recursive(entrantes_dir, ".pdf")

                jsons_generated = count_files_recursive(entrantes_dir, ".json")

                

                moved_count = total_pdfs - pdfs_remaining

                if moved_count < 0: moved_count = 0

                

                current_processed = moved_count + jsons_generated

                

                if total_pdfs > 0:

                    progress = (current_processed / total_pdfs) * 100

                    SYNC_STATE["progress"] = min(progress, 99)

                    SYNC_STATE["message"] = f"Procesando {current_processed}/{total_pdfs} documentos..."

                

                # 2. Check for New Data in En Progreso

                current_folders = count_subdirs(en_progreso_dir)

                if current_folders > last_folders:

                    SYNC_STATE["data_version"] += 1

                    last_folders = current_folders

            

            except Exception as e:

                print(f"Monitor Loop Error: {e}")



            time.sleep(1)

            

        # Verificar resultado final de proceso 3

        if process3.returncode != 0:

            print(f"Step 3 Failed with return code {process3.returncode}")

            raise Exception(f"Fallo script procesamiento (Ver consola para detalles)")



        SYNC_STATE["progress"] = 100

        SYNC_STATE["message"] = "SincronizaciÃ³n completada"

        

    except Exception as e:

        print(f"Sync Error: {e}")

        SYNC_STATE["message"] = f"Error: {str(e)}"

        SYNC_STATE["stage"] = "error"

    finally:

        SYNC_STATE["running"] = False

        print("Background sync task finished.")



def start_sync_thread(source="auto"):

    if SYNC_STATE["running"]:

        return False

    SYNC_STATE["source"] = source

    thread = threading.Thread(target=background_sync_task)

    thread.daemon = True

    thread.start()

    return True



