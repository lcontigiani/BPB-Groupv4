    void flyerId.offsetWidth; // Reflow















    // 5. Calculate Center Target (ROW Center)







    const centerX = rowRect.left + (rowRect.width / 2);







    const centerY = rowRect.top + (rowRect.height / 2);















    // 6. Animate Flight (1.2s flight)







    flyerId.style.left = (centerX - 60) + 'px';







    flyerId.style.top = centerY + 'px';







    flyerId.style.transform = 'translate(-50%, -50%) scale(1.5)';















    flyerBtn.style.left = (centerX + 60) + 'px';







    flyerBtn.style.top = centerY + 'px';







    flyerBtn.style.width = '42px';







    flyerBtn.style.height = '42px';







    flyerBtn.style.borderRadius = '50%';







    flyerBtn.style.border = '2px solid #2ecc71';







    flyerBtn.innerHTML = '&#10003;';







    flyerBtn.style.color = '#2ecc71';







    flyerBtn.style.fontSize = '1.8rem';







    flyerBtn.style.padding = '0';







    flyerBtn.style.boxShadow = '0 0 15px rgba(46, 204, 113, 0.3)';







    flyerBtn.style.background = 'rgba(0,0,0,0.8)';







    flyerBtn.style.transform = 'translate(-50%, -50%)';















    // 7. Glow (Starts at 1.2s, lasts 0.8s)







    setTimeout(() => {







        flyerId.classList.add('fly-glow-burst');







        flyerBtn.classList.add('fly-glow-burst');







    }, 1200);















    // 8. Collapse Row (Starts at 2.0s, after glow finishes)







    setTimeout(() => {







        row.style.visibility = 'visible'; // Visible for collapsing effect







        row.classList.add('row-collapsing');















        // Remove flyers







        flyerId.remove();







        flyerBtn.remove();







    }, 2000);















    // 9. Final Removal (Starts at 2.5s, 0.5s for collapse)







    setTimeout(() => {







        row.remove();















        // Remove from data source







        const idx = allData.findIndex(p => p.id === poId);







        if (idx > -1) allData.splice(idx, 1);















    }, 2500);







}















function approvePORegistryV4(poId, btn) {







    console.log("Starting approvePORegistryV4", poId);







    const po = allData.find(d => d.id === poId);







    if (!po) {







        console.error("PO not found in allData");







        return;







    }















    // Check Approval Status







    const products = po.files.pdfs || [];







    const total = products.length;







    const approvedList = getApprovedItems(poId);







    const approvedCount = approvedList.length;















    // Logic: If there are products and not all are approved -> Warning







    if (total > 0 && approvedCount < total) {







        const unapprovedCount = total - approvedCount;







        const msg = `







            Existen <strong>${unapprovedCount}</strong> Productos sin Registro Aprobado.<br>







            ÂżDeseas aprobar igualmente el registro?<br><br>







            <span style="color: #bbb; font-size: 0.9rem;">Los productos no aprobados no seran cargados en Registros.</span>







        `;















        showConfirm(msg, () => {







            console.log("Confirmed approval for", poId);







            executeApprovalAnimation(poId, btn);







        }, 'Advertencia', '#e74c3c'); // Red title







    } else {







        // 100% or empty (handle as success)







        executeApprovalAnimation(poId, btn);







    }







}















function executeApprovalAnimation(poId, btn) {







    console.log("Executing Animation for", poId);







    const row = document.getElementById(`row-${poId}`);







    if (!row) {







        console.error("Row not found for", poId);







        return;







    }















    // 0. Immediate UI Feedback: Hide interactions & content







    row.style.pointerEvents = 'none';















    // 1. Capture Rects BEFORE hiding (Critical!)







    const idCell = row.querySelector('.po-id-cell strong');







    if (!idCell) {







        console.error("ID Cell not found");







        return;







    }







    const idRect = idCell.getBoundingClientRect();















    // Safety check for button







    let btnElement = btn;







    let btnRect = btn.getBoundingClientRect();







    // If button is detached (0 width) likely due to modal, try finding it in row







    if (btnRect.width === 0) {







        console.log("Button detached or hidden, fallback searching in row...");







        const rowBtn = row.querySelector('.btn-approve');







        if (rowBtn) {







            btnElement = rowBtn;







            btnRect = rowBtn.getBoundingClientRect();







        }







    }







    console.log("Button Rect:", btnRect);















    const rowRect = row.getBoundingClientRect();















    // 2. Clone Elements







    // 2. Clone Elements







    const flyerId = idCell.cloneNode(true);







    const flyerBtn = btnElement.cloneNode(true);















    // 3. Hide Originals visually (preserving space) - INSTANTLY







    // Aggressive hiding: Hide row AND all cells AND BUTTONS to prevent any persistence







    // Use OPACITY 0 !important instead of visibility:hidden to potentially force a render usage







    row.style.setProperty('opacity', '0', 'important');







    row.style.setProperty('visibility', 'hidden', 'important');















    Array.from(row.children).forEach(child => {







        child.style.setProperty('visibility', 'hidden', 'important');







        child.style.setProperty('opacity', '0', 'important');







    });















    row.querySelectorAll('button').forEach(b => {







        b.style.setProperty('visibility', 'hidden', 'important');







        b.style.setProperty('opacity', '0', 'important');







        b.style.display = 'none'; // Nuclear option for buttons







    });















    // 4. Setup Flyers (Force visible because source is now hidden)







    flyerBtn.style.visibility = 'visible';







    flyerBtn.style.opacity = '1';







    flyerId.style.visibility = 'visible';







    flyerId.style.opacity = '1';















    // 4. Setup Flyers (Force visible because source is now hidden)







    flyerBtn.style.opacity = '1';







    flyerBtn.style.visibility = 'visible';







    flyerId.style.visibility = 'visible'; // Ensure ID clone is visible too















    // 5. Setup Flyers Styles







    flyerId.className = 'fly-element';







    flyerId.style.top = idRect.top + 'px';







    flyerId.style.left = idRect.left + 'px';







    flyerId.style.width = idRect.width + 'px';







    flyerId.style.margin = '0';







    flyerId.style.color = 'var(--text-primary)';







    flyerId.style.display = 'flex';







    flyerId.style.alignItems = 'center';







    // Faster Transition for flight







    flyerId.style.transition = 'all 0.8s cubic-bezier(0.19, 1, 0.22, 1)';















    flyerBtn.className = 'fly-element';







    flyerBtn.style.top = btnRect.top + 'px';







    flyerBtn.style.left = btnRect.left + 'px';







    flyerBtn.style.width = btnRect.width + 'px';







    flyerBtn.style.height = btnRect.height + 'px';







    flyerBtn.style.background = 'transparent'; // Keep transparent to match







    flyerBtn.style.border = '1px solid #2ecc71';







    flyerBtn.style.color = '#2ecc71';







    flyerBtn.style.display = 'flex';







    flyerBtn.style.alignItems = 'center';







    flyerBtn.style.justifyContent = 'center';







    // Faster Transition for flight







    flyerBtn.style.transition = 'all 0.8s cubic-bezier(0.19, 1, 0.22, 1)';







    flyerBtn.innerHTML = 'Aprobar Registro';















    document.body.appendChild(flyerId);







    document.body.appendChild(flyerBtn);















    void flyerId.offsetWidth; // Reflow















    // 6. Calculate Center Target (ROW Center)







    const centerX = rowRect.left + (rowRect.width / 2);







    const centerY = rowRect.top + (rowRect.height / 2);















    // 6. Animate Flight (0.8s flight - faster)







    flyerId.style.left = (centerX - 60) + 'px';







    flyerId.style.top = centerY + 'px';







    flyerId.style.transform = 'translate(-50%, -50%) scale(1.3)';















    flyerBtn.style.left = (centerX + 60) + 'px';







    flyerBtn.style.top = centerY + 'px';







    flyerBtn.style.width = '35px';







    flyerBtn.style.height = '35px';







    flyerBtn.style.borderRadius = '50%';







    flyerBtn.style.border = '2px solid #2ecc71';







    flyerBtn.innerHTML = '&#10003;';







    flyerBtn.style.color = '#2ecc71';







    flyerBtn.style.fontSize = '1.4rem';







    flyerBtn.style.padding = '0';







    flyerBtn.style.boxShadow = '0 0 15px rgba(46, 204, 113, 0.3)';







    flyerBtn.style.background = 'transparent'; // No background







    flyerBtn.style.transform = 'translate(-50%, -50%)';















    // 7. Glow (Starts at 0.8s, lasts 0.8s)







    setTimeout(() => {







        flyerId.classList.add('fly-glow-burst');







        flyerBtn.classList.add('fly-glow-burst');







    }, 800);















    // 8. Collapse Row (Starts at 1.4s, slightly overlapping end of glow or right after)







    // Glow ends at 0.8 + 0.8 = 1.6s. Let's start collapse closer to end of visual glow.







    setTimeout(() => {







        // row.style.visibility = 'visible'; // Visible for collapsing effect







        row.classList.add('row-collapsing');















        // Remove flyers







        flyerId.remove();







        flyerBtn.remove();







    }, 1400);















    // 9. Final Removal (Starts at 1.9s, 0.5s for collapse)







    setTimeout(() => {







        row.remove();















        // Remove from data source







        const idx = allData.findIndex(p => p.id === poId);







        if (idx > -1) allData.splice(idx, 1);







        if (typeof updatePOCounterUI === 'function') updatePOCounterUI();















    }, 1900);















    // 10. Trigger Server Side Action (Move Folder) - Moved to end for responsiveness















    // Calculate counts to save in metadata







    let approvedCount = 0;







    let totalCount = 0;







    const po = allData.find(d => d.id === poId);







    if (po && po.files && po.files.pdfs) {







        totalCount = po.files.pdfs.length;







        const approvedList = getApprovedItems(poId);







        approvedCount = approvedList.length;







    }















    const approvedItems = getApprovedItems(poId);















    fetch('/api/approve-po', {







        method: 'POST',







        headers: { 'Content-Type': 'application/json' },







        body: JSON.stringify({







            po_id: poId,







            approved_count: approvedCount,







            total_count: totalCount,







            approved_items: approvedItems







        })







    }).then(res => res.json())







        .then(data => {







            console.log("Approval Response:", data);







            if (data.status !== 'success') {







                alert("Error al aprobar: " + data.message);







                // Revert UI if needed (reload)







                location.reload();







            }







        }).catch(err => {







            console.error(err);







            alert("Error de conexiĂłn al aprobar: " + err);







        });







}























// --- Auxiliary Table Loader ---







async function loadAuxTable(poId, productCode, containerId) {







    const container = document.getElementById(containerId);







    if (!container) return;















    container.innerHTML = '<div style="text-align:center; padding: 1rem; color: var(--text-secondary);"><div class="spinner"></div> Buscando informaciĂłn auxiliar...</div>';















    console.log(`[loadAuxTable] Buscando aux para PO: ${poId}, Codigo: ${productCode}`);















    try {







        const response = await fetch('/api/product-aux-details', {







            method: 'POST',







            headers: { 'Content-Type': 'application/json' },







            body: JSON.stringify({ po_id: poId, product_code_a: productCode })







        });















        const data = await response.json();















        if (data.status === 'success') {















            // Normalize to array (support new multi-match and old single-match)







            let matches = [];







            if (data.matches) {







                matches = data.matches;







            } else if (data.row) {







                matches.push({







                    headers: data.headers,







                    row: data.row,







                    filename: data.filename,







                    score: 100 // Assume exact for legacy







                });







            }















            // POPULATE CUSTOM DROPDOWN







            const menu = document.getElementById('aux-dropdown-menu');







            const triggerText = document.getElementById('aux-dropdown-selected-text');







            const hiddenInput = document.getElementById('aux-placement-value');















            if (menu) {







                // Prepare "New Line" Item







                menu.innerHTML = ''; // Clear







                const newLn = document.createElement('div');







                newLn.className = 'aux-option-item';







                newLn.style.cssText = "padding: 10px 14px; cursor: pointer; font-size: 0.85rem; color: #eee; border-bottom: 1px solid rgba(255,255,255,0.05); white-space: nowrap;";







                newLn.textContent = 'Nueva Linea';







                newLn.onclick = function () { window.selectAuxOption('new', 'Nueva Linea', poId, productCode); };







                newLn.onmouseenter = function () { this.style.background = 'rgba(255,255,255,0.1)'; this.style.color = '#fff'; };







                newLn.onmouseleave = function () { this.style.background = 'transparent'; this.style.color = '#eee'; };







                menu.appendChild(newLn);















                let defaultSet = false;







                if (matches.length > 0) {







                    matches.forEach((m, i) => {







                        const label = m.match_val || m.filename;







                        const val = m.filename + '_' + i;







                        const score = m.score || 0;















                        // Default logic: If 99.9%+ match, set as default







                        if (!defaultSet && score >= 99.9) {







                            window.selectAuxOption(val, label, poId, productCode);







                            defaultSet = true;







                        }















                        const item = document.createElement('div');







                        item.style.cssText = "padding: 10px 14px; cursor: pointer; font-size: 0.85rem; color: #eee; border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.2s; white-space: nowrap;";







                        item.textContent = label;







                        item.onclick = function () { window.selectAuxOption(val, label, poId, productCode); };















                        // Hover interactions







                        item.onmouseenter = function () { this.style.background = 'rgba(255,255,255,0.1)'; this.style.color = '#fff'; };







                        item.onmouseleave = function () { this.style.background = 'transparent'; this.style.color = '#eee'; };















                        menu.appendChild(item);







                    });







                }















                if (!defaultSet) {







                    window.selectAuxOption('new', 'Nueva Linea', poId, productCode);







                }







            }















            if (matches.length > 0) {







                let html = `







                <!-- Section Divider -->







                <div style="margin-top: 1.5rem; margin-bottom: 1rem;">







                    <h3 style="color: #ce1919; font-size: 1.1rem; margin-bottom: 0.5rem; font-weight: 600; letter-spacing: 0.5px;">Datos de Registro (Top ${matches.length} Coincidencias)</h3>







                    <div style="height: 1px; background: #333; width: 100%;"></div>







                </div>







                `;















                matches.forEach((match, idx) => {







                    const safeId = 'aux_' + Math.random().toString(36).substr(2, 9);







                    const headers = match.headers || [];







                    const row = match.row || [];







                    const scoreDisplay = match.score ? Math.round(match.score) : 0;







                    const valDisplay = match.match_val ? `(Coincide con: "<strong>${match.match_val}</strong>")` : '';















                    // Color code score







                    let scoreColor = '#4caf50'; // Green







                    if (scoreDisplay < 100) scoreColor = '#ff9800'; // Orange







                    if (scoreDisplay < 50) scoreColor = '#f44336'; // Red















                    html += `







                    <!-- Aux Table Match #${idx + 1} -->







                    <div style="width: 100%; max-width: 100%; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 1rem;">







                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: rgba(255,255,255,0.05); border-bottom: 1px solid var(--border);">







                            <div style="font-size: 0.9rem; color: var(--text-primary); display:flex; align-items:center; gap: 10px;">







                                <div style="background: ${scoreColor}; color: #000; padding: 2px 6px; border-radius: 4px; font-weight:bold; font-size: 0.8rem;">${scoreDisplay}%</div>







                                <strong>${match.filename}</strong>







                                <span style="color: var(--text-secondary); font-size: 0.8rem;">${valDisplay}</span>







                            </div>







                        </div>







                        <div class="table-container" style="border:none;">







                            <table class="csv-data-table product-detail-table" id="table-${safeId}">







                                <thead>







                                    <tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr>







                                </thead>







                                <tbody>







                                    <tr>${row.map(cell => `<td>${cell || ''}</td>`).join('')}</tr>







                                </tbody>







                            </table>







                        </div>







                    </div>







                    `;







                });















                // Clear and Insert







                container.innerHTML = '';







                container.innerHTML = html;







            } else {







                container.innerHTML = '';







                container.innerHTML = '<div style="padding: 1rem; text-align: center; color: var(--text-secondary); font-style: italic; font-size: 0.9rem;">No hay informaciĂłn auxiliar vinculada encontrada.</div>';







            }















        } else {







            // Error handling







            if (data.status === 'not_found' || data.status === 'error') {







                container.innerHTML = '';







                container.innerHTML = '<div style="padding: 1rem; text-align: center; color: var(--text-secondary); font-style: italic; font-size: 0.9rem;">No hay informaciĂłn auxiliar vinculada.</div>';







            }







        }







    } catch (e) {







        console.error("Error loading aux table:", e);







        container.innerHTML = '';







    }







}







// --- Custom Dropdown Helpers ---







window.toggleAuxDropdown = function () {







    const menu = document.getElementById('aux-dropdown-menu');







    const trigger = document.getElementById('aux-dropdown-trigger');







    if (menu) {







        const isHidden = menu.style.display === 'none';







        menu.style.display = isHidden ? 'block' : 'none';







        if (trigger) trigger.style.borderColor = isHidden ? 'var(--bpb-blue)' : 'var(--text-secondary)';







    }







};















window.selectAuxOption = function (val, label, poId, productCode) {







    const input = document.getElementById('aux-placement-value');







    const textSpan = document.getElementById('aux-dropdown-selected-text');







    const menu = document.getElementById('aux-dropdown-menu');







    const trigger = document.getElementById('aux-dropdown-trigger');















    if (input) input.value = val;







    if (textSpan) textSpan.textContent = label;







    if (menu) menu.style.display = 'none';







    if (trigger) trigger.style.borderColor = 'var(--text-secondary)';















    // SAVE STATE







    if (poId && productCode) {







        fetch('/api/save-aux-target', {







            method: 'POST',







            headers: { 'Content-Type': 'application/json' },







            body: JSON.stringify({ po_id: poId, product_code: productCode, target: val })







        }).catch(err => console.error("Error saving target:", err));







    }







};















// Global click to close dropdown







document.addEventListener('click', function (e) {







    const trigger = document.getElementById('aux-dropdown-trigger');







    const menu = document.getElementById('aux-dropdown-menu');







    if (trigger && menu && !trigger.contains(e.target) && !menu.contains(e.target)) {







        menu.style.display = 'none';







        trigger.style.borderColor = 'var(--text-secondary)';







    }







});















// --- Edit Logic ---







window.refreshPOData = async function () {







    try {







        const response = await fetch('/api/data?_t=' + Date.now()); // Anti-cache







        if (response.ok) {







            const newData = await response.json();







            // CRITICAL: Update the global 'let' variable, not just window property







            allData = newData;







            window.allData = newData;







            if (typeof updatePOCounterUI === 'function') updatePOCounterUI();







        }







    } catch (e) {







        console.error("Failed to refresh data", e);







    }







};















window.enableEdit = function (safeId) {







    const table = document.getElementById('table-' + safeId);







    if (!table) return;















    const btnMod = document.getElementById('btn-mod-' + safeId);







    const actions = document.getElementById('actions-' + safeId);















    // UI Toggle







    if (btnMod) btnMod.style.display = 'none';







    if (actions) actions.style.display = 'flex';















    // Freeze column widths







    const ths = table.querySelectorAll('thead th');







    ths.forEach(th => {







        const w = th.getBoundingClientRect().width;







        th.style.width = w + 'px';







        th.style.minWidth = w + 'px'; // Freeze







        th.style.boxSizing = 'border-box';







    });















    const rows = table.querySelectorAll('tbody tr');







    rows.forEach(row => {







        const cells = row.querySelectorAll('td');







        cells.forEach(cell => {







            const val = cell.innerText;







            // Save original value for soft cancel







            cell.setAttribute('data-original', val);















            // Inject input







            cell.innerHTML = `<input type="text" value="${val.replace(/"/g, '&quot;')}" 







                style="width: 100%; min-width: 50px; background: rgba(0,0,0,0.2); border: 1px solid #555; color: inherit; padding: 2px 4px; border-radius: 4px;">`;







        });







    });







};















window.cancelEdit = function () {







    // Soft Cancel: Revert UI without reload







    // We need safeId. Since this is global, we need a way to know which table.







    // Hack: Find the visible actions container to deduce safeId.







    const actions = document.querySelector('[id^="actions-"][style*="display: flex"]');







    if (!actions) {







        // Fallback to reload if state lost







        if (window.currentProductView) {







            viewProductDetails(window.currentCSVPOD, window.currentProductView.pdfName, window.currentProductView.type);







        }







        return;







    }















    const safeId = actions.id.replace('actions-', '');







    const table = document.getElementById('table-' + safeId);







    const btnMod = document.getElementById('btn-mod-' + safeId);















    if (table) {







        const rows = table.querySelectorAll('tbody tr');







        rows.forEach(row => {







            const cells = row.querySelectorAll('td');







            cells.forEach(cell => {







                const original = cell.getAttribute('data-original');







                if (original !== null) {







                    cell.innerText = original;







                } else {







                    // Fallback: try to read value from input







                    const input = cell.querySelector('input');







                    if (input) cell.innerText = input.defaultValue; // Revert to initial







                }







            });







        });







    }















    if (actions) actions.style.display = 'none';







    if (btnMod) btnMod.style.display = 'flex'; // Restore Mod button







};















window.saveEdit = async function (safeId, poId, filename) {







    const table = document.getElementById('table-' + safeId);







    if (!table) return;















    const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.innerText.trim());







    const dataRows = [];















    const trs = table.querySelectorAll('tbody tr');







    trs.forEach(tr => {







        const obj = {};







        const inputs = tr.querySelectorAll('input');







        if (inputs.length > 0) {







            inputs.forEach((input, index) => {







                if (headers[index]) obj[headers[index]] = input.value;







            });







            dataRows.push(obj);







        }







    });















    // Interaction Feedback







    const btnSave = document.getElementById('btn-save-' + safeId);







    // Note: btnCancel might be wrapped or sibling. In our HTML structure they are siblings.







    const btnCancel = btnSave ? btnSave.previousElementSibling : null;















    if (btnSave) {







        btnSave.disabled = true;







        btnSave.classList.add('btn-loading-pulse');







        // btnSave.style.opacity was removed in favor of pulsing class







    }







    if (btnCancel) btnCancel.style.display = 'none'; // Hide cancel during save















    try {







        const res = await fetch('/api/update_csv', {







            method: 'POST',







            headers: { 'Content-Type': 'application/json' },







            body: JSON.stringify({ po_id: poId, filename: filename, rows: dataRows })







        });







        const d = await res.json();















        if (d.status === 'success') {







            // Wait for filesystem (800ms)







            await new Promise(r => setTimeout(r, 800));







            // Refresh Data







            await window.refreshPOData();















            // Re-Render view completely







            viewProductDetails(window.currentCSVPOD, window.currentProductView.pdfName, window.currentProductView.type);















        } else {







            alert("Error al guardar: " + (d.message || "Desconocido"));







            if (btnSave) {







                btnSave.disabled = false;







                btnSave.classList.remove('btn-loading-pulse');







            }







            if (btnCancel) btnCancel.style.display = 'flex';







        }







    } catch (e) {







        console.error(e);







        alert("Error de conexiĂłn al guardar.");







        if (btnSave) {







            btnSave.disabled = false;







            btnSave.classList.remove('btn-loading-pulse');







        }







        if (btnCancel) btnCancel.style.display = 'flex';







    }







};















window.loadAuxTable = loadAuxTable;















window.showPassword = function (id) {







    const el = document.getElementById(id);







    if (el) el.type = 'text';







};















window.hidePassword = function (id) {







    const el = document.getElementById(id);







    if (el) el.type = 'password';







};















