// Check for running sync on load







function checkInitialSyncState() {







    fetch('/api/sync-progress')







        .then(res => res.json())







        .then(data => {







            if (data.running) {







                console.log("Restoring active sync state...", data.source);















                const isManual = (data.source === 'manual');















                // Select elements based on source







                const container = isManual ? document.getElementById('sync-progress-manual') : document.getElementById('sync-progress-inline');







                const btnToHide = isManual ? document.getElementById('btn-manual-upload') : document.getElementById('btn-sync-trigger');















                const bar = isManual ? document.getElementById('sync-manual-bar') : document.getElementById('sync-inline-bar');







                const text = isManual ? document.getElementById('sync-manual-text') : document.getElementById('sync-inline-text');







                const chk = isManual ? document.getElementById('sync-manual-chk') : document.getElementById('sync-inline-chk');















                if (container && btnToHide) {







                    btnToHide.style.display = 'none'; // Hide specific button







                    container.style.display = 'flex'; // Show specific progress















                    const pct = Math.round(data.progress);







                    if (bar) bar.style.width = `${pct}%`;







                    if (chk) chk.innerText = `${pct}%`;







                    if (text) text.innerText = data.message || 'Procesando...';















                    // Restart Polling







                    let lastDataVersion = -1;















                    const pollInterval = setInterval(() => {







                        fetch('/api/sync-progress')







                            .then(pRes => pRes.json())







                            .then(pData => {







                                // Smart Refresh: Update only if backend signals new data







                                if (pData.data_version !== undefined) {







                                    if (lastDataVersion === -1) lastDataVersion = pData.data_version; // init















                                    if (pData.data_version > lastDataVersion) {







                                        console.log("New data detected, refreshing...");







                                        if (document.getElementById('view-list').style.display === 'block') {







                                            fetchData();







                                        }







                                        lastDataVersion = pData.data_version;







                                    }







                                }















                                // Update UI







                                if (container) {







                                    const pct = Math.round(pData.progress);







                                    if (bar) bar.style.width = `${pct}%`;







                                    if (chk) chk.innerText = `${pct}%`;







                                    if (text) text.innerText = pData.message || 'Procesando...';







                                }















                                if (!pData.running) {







                                    clearInterval(pollInterval);







                                    setTimeout(() => {







                                        if (pData.stage !== 'error') {







                                            if (pData.message && pData.message.includes("No se encontraron")) {







                                                showNotification(pData.message, 'warning');







                                            } else {







                                                showNotification('SincronizaciĂłn completada', 'success');







                                                if (document.getElementById('view-list').style.display === 'block') {







                                                    fetchData();







                                                }







                                            }







                                        } else {







                                            showNotification(pData.message, 'error');







                                        }















                                        // RESTORE UI







                                        if (container && btnToHide) {







                                            container.style.display = 'none';







                                            btnToHide.style.display = 'inline-block';















                                            // Reset text







                                            if (isManual) {







                                                btnToHide.innerHTML = '<span style="margin-right: 5px;">+</span> Cargar Registro Manual';







                                                // Ensure button is re-enabled if it was disabled elsewhere







                                                btnToHide.disabled = false;







                                            } else {







                                                btnToHide.innerHTML = '<span style="margin-right: 5px;">+</span> Buscar Nuevos Registros';







                                                btnToHide.disabled = false;







                                            }







                                        }







                                    }, 1500);







                                }







                            })







                            .catch(e => console.error("Poll Error", e));







                    }, 1000);







                }







            }







        })







        .catch(e => console.error("Initial Sync Check Error", e));







}















// Auto-run on load and Restore View







document.addEventListener('DOMContentLoaded', () => {







    checkInitialSyncState();















    const last = localStorage.getItem('lastView');







    if (last) {







        console.log('Restoring view:', last);







        // Small delay to ensure DOM readiness overrides defaults







        setTimeout(() => {







            switch (last) {







                case 'home': showHome(); break;







                case 'subhome': showSubHome(); break;







                case 'po-module': showPOModule(); break;







                case 'upload': showUploadView(); break;







                case 'aux-indices': showAuxiliarIndices(); break;







                case 'historial': showHistorialPOList(); break;







                case 'r016': showR016List(); break;















                case 'profile': showProfileView(); break;







                case 'admin': showAdminPanel(); break;















                // Detailed Views







                case 'aux-csv':







                    const p1 = localStorage.getItem('lastViewParam');







                    if (p1) viewAuxiliarCSV(p1);







                    else showR016List();







                    break;







                case 'historial-detail':







                    const p2 = localStorage.getItem('lastViewParam');







                    if (p2) viewHistorialDetails(p2);







                    else showHistorialPOList();







                    break;















                default: showHome();







            }







        }, 50);







    }







});















// Quick Image Viewer Logic







function viewImage(src) {







    const modalId = 'image-viewer-modal';







    const existing = document.getElementById(modalId);







    if (existing) existing.remove();















    const modal = document.createElement('div');







    modal.id = modalId;







    modal.className = 'modal-overlay';







    modal.style.display = 'flex';







    modal.style.justifyContent = 'center';







    modal.style.alignItems = 'center';







    modal.style.zIndex = '10000';







    modal.style.background = 'rgba(0,0,0,0.85)';







    modal.style.cursor = 'zoom-out';







    modal.style.opacity = '0';







    modal.style.transition = 'opacity 0.3s ease';















    // Close on click anywhere







    modal.onclick = () => {







        modal.style.opacity = '0';







        setTimeout(() => modal.remove(), 300);







    };















    modal.innerHTML = `







        <div style="position: relative; max-width: 90vw; max-height: 90vh;">







            <img src="${src}" style="







                max-width: 100%; 







                max-height: 90vh; 







                border-radius: 8px; 







                box-shadow: 0 0 30px rgba(0,0,0,0.6); 







                cursor: default;







                object-fit: contain;







                border: 2px solid #333;







            " onclick="event.stopPropagation()">







            <div style="







                position: absolute; 







                top: -40px; 







                right: -40px; 







                color: white; 







                font-size: 2rem; 







                cursor: pointer; 







                font-weight: bold;







                text-shadow: 0 0 10px black;







                width: 40px; 







                height: 40px; 







                text-align: center; 







                line-height: 40px;







            " onclick="document.getElementById('${modalId}').click()">&times;</div>







        </div>







    `;















    document.body.appendChild(modal);















    // Animate In







    requestAnimationFrame(() => {







        modal.style.opacity = '1';







    });







}















// Event Delegation for Manual Register Buttons







// Event Delegation for Dynamic Buttons (Manual Register & Approve All)







document.addEventListener('click', function (e) {







    // 1. Manual Register







    const regBtn = e.target.closest('.btn-register-manual');







    if (regBtn) {







        const poId = regBtn.getAttribute('data-po');







        if (poId) {







            registerManualPO(poId);







        }







    }















    // 2. Approve All Products







    const apprBtn = e.target.closest('.btn-approve-all');







    if (apprBtn) {







        const poId = apprBtn.getAttribute('data-poid');







        if (poId) {







            approveAllProducts(poId);







        }







    }







});















