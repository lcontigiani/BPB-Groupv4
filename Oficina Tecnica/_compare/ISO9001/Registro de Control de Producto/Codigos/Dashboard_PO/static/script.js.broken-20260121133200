                     clearInterval(pollInterval);\n                            Swal.fire('Error', statusData.message, 'error');\n                        }\n                    })\n                    .catch(e => console.error("Polling error", e));\n            }, 2000);\n        } else {\n            Swal.fire('Error', data.message || 'Error al iniciar aprobación', 'error');\n        }\n    })\n    .catch(err => {\n        console.error(err);\n        Swal.fire('Error', 'Error de conexión al iniciar aprobación: ' + err, 'error');\n    });\n\n\n\n\n\n\n\n}\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n*/\n// --- Auxiliary Table Loader ---\n\n\n\n\n\n\n\nasync function loadAuxTable(poId, productCode, containerId) {\n\n\n\n\n\n\n\n    const container = document.getElementById(containerId);\n\n\n\n\n\n\n\n    if (!container) return;\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    container.innerHTML = '<div style="text-align:center; padding: 1rem; color: var(--text-secondary);"><div class="spinner"></div> Buscando información auxiliar...</div>';\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    console.log(`[loadAuxTable] Buscando aux para PO: ${poId}, Codigo: ${productCode}`);\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    try {\n\n\n\n\n\n\n\n        const response = await fetch('/api/product-aux-details', {\n\n\n\n\n\n\n\n            method: 'POST',\n\n\n\n\n\n\n\n            headers: { 'Content-Type': 'application/json' },\n\n\n\n\n\n\n\n            body: JSON.stringify({ po_id: poId, product_code_a: productCode })\n\n\n\n\n\n\n\n        });\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n        const data = await response.json();\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n        if (data.status === 'success') {\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n            // Normalize to array (support new multi-match and old single-match)\n\n\n\n\n\n\n\n            let matches = [];\n\n\n\n\n\n\n\n            if (data.matches) {\n\n\n\n\n\n\n\n                matches = data.matches;\n\n\n\n\n\n\n\n            } else if (data.row) {\n\n\n\n\n\n\n\n                matches.push({\n\n\n\n\n\n\n\n                    headers: data.headers,\n\n\n\n\n\n\n\n                    row: data.row,\n\n\n\n\n\n\n\n                    filename: data.filename,\n\n\n\n\n\n\n\n                    score: 100 // Assume exact for legacy\n\n\n\n\n\n\n\n                });\n\n\n\n\n\n\n\n            }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n            // POPULATE CUSTOM DROPDOWN\n\n\n\n\n\n\n\n            const menu = document.getElementById('aux-dropdown-menu');\n\n\n\n\n\n\n\n            const triggerText = document.getElementById('aux-dropdown-selected-text');\n\n\n\n\n\n\n\n            const hiddenInput = document.getElementById('aux-placement-value');\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n            if (menu) {\n\n\n\n\n\n\n\n                // Prepare "New Line" Item\n\n\n\n\n\n\n\n                menu.innerHTML = ''; // Clear\n\n\n\n\n\n\n\n                const newLn = document.createElement('div');\n\n\n\n\n\n\n\n                newLn.className = 'aux-option-item';\n\n\n\n\n\n\n\n                newLn.style.cssText = "padding: 10px 14px; cursor: pointer; font-size: 0.85rem; color: #eee; border-bottom: 1px solid rgba(255,255,255,0.05); white-space: nowrap;";\n\n\n\n\n\n\n\n                newLn.textContent = 'Nueva Linea';\n\n\n\n\n\n\n\n                newLn.onclick = function () { window.selectAuxOption('new', 'Nueva Linea', poId, productCode); };\n\n\n\n\n\n\n\n                newLn.onmouseenter = function () { this.style.background = 'rgba(255,255,255,0.1)'; this.style.color = '#fff'; };\n\n\n\n\n\n\n\n                newLn.onmouseleave = function () { this.style.background = 'transparent'; this.style.color = '#eee'; };\n\n\n\n\n\n\n\n                menu.appendChild(newLn);\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                let defaultSet = false;\n\n\n\n\n\n\n\n                if (matches.length > 0) {\n\n\n\n\n\n\n\n                    matches.forEach((m, i) => {\n\n\n\n\n\n\n\n                        const label = m.match_val || m.filename;\n\n\n\n\n\n\n\n                        const val = m.filename + '_' + i;\n\n\n\n\n\n\n\n                        const score = m.score || 0;\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                        // Default logic: If 99.9%+ match, set as default\n\n\n\n\n\n\n\n                        if (!defaultSet && score >= 99.9) {\n\n\n\n\n\n\n\n                            window.selectAuxOption(val, label, poId, productCode);\n\n\n\n\n\n\n\n                            defaultSet = true;\n\n\n\n\n\n\n\n                        }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                        const item = document.createElement('div');\n\n\n\n\n\n\n\n                        item.style.cssText = "padding: 10px 14px; cursor: pointer; font-size: 0.85rem; color: #eee; border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.2s; white-space: nowrap;";\n\n\n\n\n\n\n\n                        item.textContent = label;\n\n\n\n\n\n\n\n                        item.onclick = function () { window.selectAuxOption(val, label, poId, productCode); };\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                        // Hover interactions\n\n\n\n\n\n\n\n                        item.onmouseenter = function () { this.style.background = 'rgba(255,255,255,0.1)'; this.style.color = '#fff'; };\n\n\n\n\n\n\n\n                        item.onmouseleave = function () { this.style.background = 'transparent'; this.style.color = '#eee'; };\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                        menu.appendChild(item);\n\n\n\n\n\n\n\n                    });\n\n\n\n\n\n\n\n                }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                if (!defaultSet) {\n\n\n\n\n\n\n\n                    window.selectAuxOption('new', 'Nueva Linea', poId, productCode);\n\n\n\n\n\n\n\n                }\n\n\n\n\n\n\n\n            }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n            if (matches.length > 0) {\n\n\n\n\n\n\n\n                let html = `\n\n\n\n\n\n\n\n                <!-- Section Divider -->\n\n\n\n\n\n\n\n                <div style="margin-top: 1.5rem; margin-bottom: 1rem;">\n\n\n\n\n\n\n\n                    <h3 style="color: #ce1919; font-size: 1.1rem; margin-bottom: 0.5rem; font-weight: 600; letter-spacing: 0.5px;">Datos de Registro (Top ${matches.length} Coincidencias)</h3>\n\n\n\n\n\n\n\n                    <div style="height: 1px; background: #333; width: 100%;"></div>\n\n\n\n\n\n\n\n                </div>\n\n\n\n\n\n\n\n                `;\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                matches.forEach((match, idx) => {\n\n\n\n\n\n\n\n                    const safeId = 'aux_' + Math.random().toString(36).substr(2, 9);\n\n\n\n\n\n\n\n                    const headers = match.headers || [];\n\n\n\n\n\n\n\n                    const row = match.row || [];\n\n\n\n\n\n\n\n                    const scoreDisplay = match.score ? Math.round(match.score) : 0;\n\n\n\n\n\n\n\n                    const valDisplay = match.match_val ? `(Coincide con: "<strong>${match.match_val}</strong>")` : '';\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                    // Color code score\n\n\n\n\n\n\n\n                    let scoreColor = '#4caf50'; // Green\n\n\n\n\n\n\n\n                    if (scoreDisplay < 100) scoreColor = '#ff9800'; // Orange\n\n\n\n\n\n\n\n                    if (scoreDisplay < 50) scoreColor = '#f44336'; // Red\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                    html += `\n\n\n\n\n\n\n\n                    <!-- Aux Table Match #${idx + 1} -->\n\n\n\n\n\n\n\n                    <div style="width: 100%; max-width: 100%; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 1rem;">\n\n\n\n\n\n\n\n                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: rgba(255,255,255,0.05); border-bottom: 1px solid var(--border);">\n\n\n\n\n\n\n\n                            <div style="font-size: 0.9rem; color: var(--text-primary); display:flex; align-items:center; gap: 10px;">\n\n\n\n\n\n\n\n                                <div style="background: ${scoreColor}; color: #000; padding: 2px 6px; border-radius: 4px; font-weight:bold; font-size: 0.8rem;">${scoreDisplay}%</div>\n\n\n\n\n\n\n\n                                <strong>${match.filename}</strong>\n\n\n\n\n\n\n\n                                <span style="color: var(--text-secondary); font-size: 0.8rem;">${valDisplay}</span>\n\n\n\n\n\n\n\n                            </div>\n\n\n\n\n\n\n\n                        </div>\n\n\n\n\n\n\n\n                        <div class="table-container" style="border:none;">\n\n\n\n\n\n\n\n                            <table class="csv-data-table product-detail-table" id="table-${safeId}">\n\n\n\n\n\n\n\n                                <thead>\n\n\n\n\n\n\n\n                                    <tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr>\n\n\n\n\n\n\n\n                                </thead>\n\n\n\n\n\n\n\n                                <tbody>\n\n\n\n\n\n\n\n                                    <tr>${row.map(cell => `<td>${cell || ''}</td>`).join('')}</tr>\n\n\n\n\n\n\n\n                                </tbody>\n\n\n\n\n\n\n\n                            </table>\n\n\n\n\n\n\n\n                        </div>\n\n\n\n\n\n\n\n                    </div>\n\n\n\n\n\n\n\n                    `;\n\n\n\n\n\n\n\n                });\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                // Clear and Insert\n\n\n\n\n\n\n\n                container.innerHTML = '';\n\n\n\n\n\n\n\n                container.innerHTML = html;\n\n\n\n\n\n\n\n            } else {\n\n\n\n\n\n\n\n                container.innerHTML = '';\n\n\n\n\n\n\n\n                container.innerHTML = '<div style="padding: 1rem; text-align: center; color: var(--text-secondary); font-style: italic; font-size: 0.9rem;">No hay información auxiliar vinculada encontrada.</div>';\n\n\n\n\n\n\n\n            }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n        } else {\n\n\n\n\n\n\n\n            // Error handling\n\n\n\n\n\n\n\n            if (data.status === 'not_found' || data.status === 'error') {\n\n\n\n\n\n\n\n                container.innerHTML = '';\n\n\n\n\n\n\n\n                container.innerHTML = '<div style="padding: 1rem; text-align: center; color: var(--text-secondary); font-style: italic; font-size: 0.9rem;">No hay información auxiliar vinculada.</div>';\n\n\n\n\n\n\n\n            }\n\n\n\n\n\n\n\n        }\n\n\n\n\n\n\n\n    } catch (e) {\n\n\n\n\n\n\n\n        console.error("Error loading aux table:", e);\n\n\n\n\n\n\n\n        container.innerHTML = '';\n\n\n\n\n\n\n\n    }\n\n\n\n\n\n\n\n}\n\n\n\n\n\n\n\n// --- Custom Dropdown Helpers ---\n\n\n\n\n\n\n\nwindow.toggleAuxDropdown = function () {\n\n\n\n\n\n\n\n    const menu = document.getElementById('aux-dropdown-menu');\n\n\n\n\n\n\n\n    const trigger = document.getElementById('aux-dropdown-trigger');\n\n\n\n\n\n\n\n    if (menu) {\n\n\n\n\n\n\n\n        const isHidden = menu.style.display === 'none';\n\n\n\n\n\n\n\n        menu.style.display = isHidden ? 'block' : 'none';\n\n\n\n\n\n\n\n        if (trigger) trigger.style.borderColor = isHidden ? 'var(--bpb-blue)' : 'var(--text-secondary)';\n\n\n\n\n\n\n\n    }\n\n\n\n\n\n\n\n};\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nwindow.selectAuxOption = function (val, label, poId, productCode) {\n\n\n\n\n\n\n\n    const input = document.getElementById('aux-placement-value');\n\n\n\n\n\n\n\n    const textSpan = document.getElementById('aux-dropdown-selected-text');\n\n\n\n\n\n\n\n    const menu = document.getElementById('aux-dropdown-menu');\n\n\n\n\n\n\n\n    const trigger = document.getElementById('aux-dropdown-trigger');\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    if (input) input.value = val;\n\n\n\n\n\n\n\n    if (textSpan) textSpan.textContent = label;\n\n\n\n\n\n\n\n    if (menu) menu.style.display = 'none';\n\n\n\n\n\n\n\n    if (trigger) trigger.style.borderColor = 'var(--text-secondary)';\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    // SAVE STATE\n\n\n\n\n\n\n\n    if (poId && productCode) {\n\n\n\n\n\n\n\n        fetch('/api/save-aux-target', {\n\n\n\n\n\n\n\n            method: 'POST',\n\n\n\n\n\n\n\n            headers: { 'Content-Type': 'application/json' },\n\n\n\n\n\n\n\n            body: JSON.stringify({ po_id: poId, product_code: productCode, target: val })\n\n\n\n\n\n\n\n        }).catch(err => console.error("Error saving target:", err));\n\n\n\n\n\n\n\n    }\n\n\n\n\n\n\n\n};\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n// Global click to close dropdown\n\n\n\n\n\n\n\ndocument.addEventListener('click', function (e) {\n\n\n\n\n\n\n\n    const trigger = document.getElementById('aux-dropdown-trigger');\n\n\n\n\n\n\n\n    const menu = document.getElementById('aux-dropdown-menu');\n\n\n\n\n\n\n\n    if (trigger && menu && !trigger.contains(e.target) && !menu.contains(e.target)) {\n\n\n\n\n\n\n\n        menu.style.display = 'none';\n\n\n\n\n\n\n\n        trigger.style.borderColor = 'var(--text-secondary)';\n\n\n\n\n\n\n\n    }\n\n\n\n\n\n\n\n});\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n// --- Edit Logic ---\n\n\n\n\n\n\n\nwindow.refreshPOData = async function () {\n\n\n\n\n\n\n\n    try {\n\n\n\n\n\n\n\n        const response = await fetch('/api/data?_t=' + Date.now()); // Anti-cache\n\n\n\n\n\n\n\n        if (response.ok) {\n\n\n\n\n\n\n\n            const newData = await response.json();\n\n\n\n\n\n\n\n            // CRITICAL: Update the global 'let' variable, not just window property\n\n\n\n\n\n\n\n            allData = newData;\n\n\n\n\n\n\n\n            window.allData = newData;\n\n\n\n\n\n\n\n            if (typeof updatePOCounterUI === 'function') updatePOCounterUI();\n\n\n\n\n\n\n\n        }\n\n\n\n\n\n\n\n    } catch (e) {\n\n\n\n\n\n\n\n        console.error("Failed to refresh data", e);\n\n\n\n\n\n\n\n    }\n\n\n\n\n\n\n\n};\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nwindow.enableEdit = function (safeId) {\n\n\n\n\n\n\n\n    const table = document.getElementById('table-' + safeId);\n\n\n\n\n\n\n\n    if (!table) return;\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    const btnMod = document.getElementById('btn-mod-' + safeId);\n\n\n\n\n\n\n\n    const actions = document.getElementById('actions-' + safeId);\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    // UI Toggle\n\n\n\n\n\n\n\n    if (btnMod) btnMod.style.display = 'none';\n\n\n\n\n\n\n\n    if (actions) actions.style.display = 'flex';\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    // Freeze column widths\n\n\n\n\n\n\n\n    const ths = table.querySelectorAll('thead th');\n\n\n\n\n\n\n\n    ths.forEach(th => {\n\n\n\n\n\n\n\n        const w = th.getBoundingClientRect().width;\n\n\n\n\n\n\n\n        th.style.width = w + 'px';\n\n\n\n\n\n\n\n        th.style.minWidth = w + 'px'; // Freeze\n\n\n\n\n\n\n\n        th.style.boxSizing = 'border-box';\n\n\n\n\n\n\n\n    });\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    const rows = table.querySelectorAll('tbody tr');\n\n\n\n\n\n\n\n    rows.forEach(row => {\n\n\n\n\n\n\n\n        const cells = row.querySelectorAll('td');\n\n\n\n\n\n\n\n        cells.forEach(cell => {\n\n\n\n\n\n\n\n            const val = cell.innerText;\n\n\n\n\n\n\n\n            // Save original value for soft cancel\n\n\n\n\n\n\n\n            cell.setAttribute('data-original', val);\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n            // Inject input\n\n\n\n\n\n\n\n            cell.innerHTML = `<input type="text" value="${val.replace(/"/g, '&quot;')}" \n\n\n\n\n\n\n\n                style="width: 100%; min-width: 50px; background: rgba(0,0,0,0.2); border: 1px solid #555; color: inherit; padding: 2px 4px; border-radius: 4px;">`;\n\n\n\n\n\n\n\n        });\n\n\n\n\n\n\n\n    });\n\n\n\n\n\n\n\n};\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nwindow.cancelEdit = function () {\n\n\n\n\n\n\n\n    // Soft Cancel: Revert UI without reload\n\n\n\n\n\n\n\n    // We need safeId. Since this is global, we need a way to know which table.\n\n\n\n\n\n\n\n    // Hack: Find the visible actions container to deduce safeId.\n\n\n\n\n\n\n\n    const actions = document.querySelector('[id^="actions-"][style*="display: flex"]');\n\n\n\n\n\n\n\n    if (!actions) {\n\n\n\n\n\n\n\n        /