[];\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    const trs = table.querySelectorAll('tbody tr');\n\n\n\n\n\n\n\n    trs.forEach(tr => {\n\n\n\n\n\n\n\n        const obj = {};\n\n\n\n\n\n\n\n        const inputs = tr.querySelectorAll('input');\n\n\n\n\n\n\n\n        if (inputs.length > 0) {\n\n\n\n\n\n\n\n            inputs.forEach((input, index) => {\n\n\n\n\n\n\n\n                if (headers[index]) obj[headers[index]] = input.value;\n\n\n\n\n\n\n\n            });\n\n\n\n\n\n\n\n            dataRows.push(obj);\n\n\n\n\n\n\n\n        }\n\n\n\n\n\n\n\n    });\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    // Interaction Feedback\n\n\n\n\n\n\n\n    const btnSave = document.getElementById('btn-save-' + safeId);\n\n\n\n\n\n\n\n    // Note: btnCancel might be wrapped or sibling. In our HTML structure they are siblings.\n\n\n\n\n\n\n\n    const btnCancel = btnSave ? btnSave.previousElementSibling : null;\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    if (btnSave) {\n\n\n\n\n\n\n\n        btnSave.disabled = true;\n\n\n\n\n\n\n\n        btnSave.classList.add('btn-loading-pulse');\n\n\n\n\n\n\n\n        // btnSave.style.opacity was removed in favor of pulsing class\n\n\n\n\n\n\n\n    }\n\n\n\n\n\n\n\n    if (btnCancel) btnCancel.style.display = 'none'; // Hide cancel during save\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    try {\n\n\n\n\n\n\n\n        const res = await fetch('/api/update_csv', {\n\n\n\n\n\n\n\n            method: 'POST',\n\n\n\n\n\n\n\n            headers: { 'Content-Type': 'application/json' },\n\n\n\n\n\n\n\n            body: JSON.stringify({ po_id: poId, filename: filename, rows: dataRows })\n\n\n\n\n\n\n\n        });\n\n\n\n\n\n\n\n        const d = await res.json();\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n        if (d.status === 'success') {\n\n\n\n\n\n\n\n            // Wait for filesystem (800ms)\n\n\n\n\n\n\n\n            await new Promise(r => setTimeout(r, 800));\n\n\n\n\n\n\n\n            // Refresh Data\n\n\n\n\n\n\n\n            await window.refreshPOData();\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n       