for running sync on load\n\n\n\n\n\n\n\nfunction checkInitialSyncState() {\n\n\n\n\n\n\n\n    fetch('/api/sync-progress')\n\n\n\n\n\n\n\n        .then(res => res.json())\n\n\n\n\n\n\n\n        .then(data => {\n\n\n\n\n\n\n\n            if (data.running) {\n\n\n\n\n\n\n\n                console.log("Restoring active sync state...", data.source);\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                const isManual = (data.source === 'manual');\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                // Select elements based on source\n\n\n\n\n\n\n\n                const container = isManual ? document.getElementById('sync-progress-manual') : document.getElementById('sync-progress-inline');\n\n\n\n\n\n\n\n                const btnToHide = isManual ? document.getElementById('btn-manual-upload') : document.getElementById('btn-sync-trigger');\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                const bar = isManual ? document.getElementById('sync-manual-bar') : document.getElementById('sync-inline-bar');\n\n\n\n\n\n\n\n                const text = isManual ? document.getElementById('sync-manual-text') : document.getElementById('sync-inline-text');\n\n\n\n\n\n\n\n                const chk = isManual ? document.getElementById('sync-manual-chk') : document.getElementById('sync-inline-chk');\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                if (container && btnToHide) {\n\n\n\n\n\n\n\n                    btnToHide.style.display = 'none'; // Hide specific button\n\n\n\n\n\n\n\n                    container.style.display = 'flex'; // Show specific progress\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                    const pct = Math.round(data.progress);\n\n\n\n\n\n\n\n                    if (bar) bar.style.width = `${pct}%`;\n\n\n\n\n\n\n\n                    if (chk) chk.innerText = `${pct}%`;\n\n\n\n\n\n\n\n                    if (text) text.innerText = data.message || 'Procesando...';\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                    // Restart Polling\n\n\n\n\n\n\n\n                    let lastDataVersion = -1;\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                    const pollInterval = setInterval(() => {\n\n\n\n\n\n\n\n                        fetch('/api/sync-progress')\n\n\n\n\n\n\n\n                            .then(pRes => pRes.json())\n\n\n\n\n\n\n\n                            .then(pData => {\n\n\n\n\n\n\n\n                                // Smart Refresh: Update only if backend signals new data\n\n\n\n\n\n\n\n                                if (pData.data_version !== undefined) {\n\n\n\n\n\n\n\n                                    if (lastDataVersion === -1) lastDataVersion = pData.data_version; // init\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                                    if (pData.data_version > lastDataVersion) {\n\n\n\n\n\n\n\n                                        console.log("New data detected, refreshing...");\n\n\n\n\n\n\n\n                                        if (document.getElementById('view-list').style.display === 'block') {\n\n\n\n\n\n\n\n                                            fetchData();\n\n\n\n\n\n\n\n                                        }\n\n\n\n\n\n\n\n                                        lastDataVersion = pData.data_version;\n\n\n\n\n\n\n\n                                    }\n\n\n\n\n\n\n\n                                }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                                // Update UI\n\n\n\n\n\n\n\n                                if (container) {\n\n\n\n\n\n\n\n                                    const pct = Math.round(pData.progress);\n\n\n\n\n\n\n\n                                    if (bar) bar.style.width = `${pct}%`;\n\n\n\n\n\n\n\n                                    if (chk) chk.innerText = `${pct}%`;\n\n\n\n\n\n\n\n                                    if (text) text.innerText = pData.message || 'Procesando...';\n\n\n\n\n\n\n\n                                }\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n                                if (!pData.running) {\n\n\n\n\n\n\n\n                                    clearInterval(pollInt